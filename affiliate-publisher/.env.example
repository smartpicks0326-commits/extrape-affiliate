# ---------- Server ----------
PORT=4000
BASE_URL=https://publisher.smartpickdeals.live

# ---------- PostgreSQL ----------
DATABASE_URL=postgres://user:password@localhost:5432/smartpickdeals
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=changeme
PGDATABASE=smartpickdeals

# ---------- Amazon Product Advertising API ----------
# Leave ACCESS_KEY/SECRET_KEY blank until PA-API approval comes through.
# AMAZON_MOCK_MODE=true lets the pipeline run against sample data meanwhile.
AMAZON_ASSOCIATE_TAG=your-associate-tag-20
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_REGION=us-east-1
AMAZON_MOCK_MODE=true

# ---------- Pinterest API ----------
# Register app at https://developer.pinterest.com to get these.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_MOCK_MODE=true

# ---------- Extrape ----------
EXTRAPE_API_KEY=
EXTRAPE_BASE_URL=

# ---------- AI (Anthropic Claude) ----------
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# ---------- Cloudflare R2 (backups) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=smartpickdeals-backups
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ---------- Scheduler ----------
CRON_INTERVAL=*/30 * * * *
BACKUP_CRON=0 3 * * *
